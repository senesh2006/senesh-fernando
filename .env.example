# Firebase (Firestore) — service account from Firebase Console → Project settings → Service accounts
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste private key with \n for line breaks, or use real newlines in quotes
FIREBASE_PRIVATE_KEY=

# NextAuth — required for /admin login
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://your-domain.vercel.app

# GitHub OAuth — https://github.com/settings/developers
# Authorization callback URL: https://your-domain.vercel.app/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=
GITHUB_ALLOWED_USERNAME=senesh2006

# Optional: shown on login page (defaults to GITHUB_ALLOWED_USERNAME)
NEXT_PUBLIC_GITHUB_ALLOWED_USERNAME=senesh2006

# Optional: contact form email
RESEND_API_KEY=
