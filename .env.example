# Neon PostgreSQL — https://neon.tech
# Use the pooled connection string from your Neon project dashboard.
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Canonical site URL — must match the domain in your browser
SITE_URL=https://v0-senesh-fernando.vercel.app
NEXTAUTH_URL=https://v0-senesh-fernando.vercel.app
NEXTAUTH_SECRET=

# GitHub OAuth — https://github.com/settings/developers
# Authorization callback URL (must match exactly):
# https://v0-senesh-fernando.vercel.app/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=
GITHUB_ALLOWED_USERNAME=senesh2006

# Shown on the admin login page
NEXT_PUBLIC_SITE_URL=https://v0-senesh-fernando.vercel.app
NEXT_PUBLIC_GITHUB_ALLOWED_USERNAME=senesh2006

# Optional: contact form email
RESEND_API_KEY=

# Optional: higher GitHub API rate limits
GITHUB_TOKEN=

# TanStack frontend origin(s) allowed to call public /api routes (comma-separated)
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Set to true to show a site-wide maintenance screen (/admin still accessible)
MAINTENANCE_MODE=false
